{
  "manifest_version": 3,
  "name": "绷着脸",
  "short_name": "绷着脸",
  "version": "1.0.6",
  "description": "绷着脸 StiffEyes：页面资产梳理、技术指纹、Spring 探测、Webpack 映射。仅限授权安全测试。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webRequest",
    "downloads"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/scan-config.js",
        "lib/scan-filter.js",
        "lib/scan-engine.js",
        "lib/patterns.js",
        "content/webpack-collector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "绷着脸 · 网检"
  }
}
