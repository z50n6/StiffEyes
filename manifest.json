{
  "manifest_version": 3,
  "name": "绷着脸",
  "short_name": "绷着脸",
  "version": "1.1.8",
  "description": "绷着脸 StiffEyes：页面资产梳理、技术指纹、Spring 探测、Webpack 映射、云存储 Bucket 发现与漏洞检测。仅限授权安全测试。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webRequest",
    "webNavigation",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.mir6.com/*",
    "https://cn.apihz.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/logger.js",
        "lib/scan-config.js",
        "lib/scan-filter.js",
        "lib/scan-engine.js",
        "content/webpack-collector.js",
        "content/sniff-collector.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "绷着脸"
  }
}
